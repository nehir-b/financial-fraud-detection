      <column caption='Percentile Filter' datatype='boolean' name='[Calculation_1974236601962496]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[amt] &lt;= { FIXED : PERCENTILE([amt], 0.99) }' />
      </column>
      <column caption=' Inflation-Adjusted Transaction Amounts vs ' datatype='real' name='[Calculation_1974236681162753]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[amt] * (1 + 0.02) ^ &#13;&#10;(YEAR(TODAY()) - YEAR([trans_date_trans_time]))' />
      </column>
